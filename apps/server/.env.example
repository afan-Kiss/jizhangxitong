PORT=3001
SERVER_PORT=3001
NODE_ENV=development
DATABASE_URL="file:./data/accounting.db"

# 生产环境请改为强随机密钥（至少32位）
JWT_SECRET="change-this-in-production"
JWT_EXPIRES_IN="7d"

# Worker WebSocket 鉴权（生产必填）
WORKER_WS_TOKEN="dev-worker-token-change-in-production"

# 跨域（生产填前端域名，如 https://account.example.com）
CORS_ORIGIN="*"

# 是否强制要求 Worker 在线才能上传/导出
LOCAL_WORKER_REQUIRED=false

# 扫码绑定功能（默认关闭，设为 true 可恢复）
# SCAN_BINDING_ENABLED=false

EXPORT_DIR="./exports"
EXPORT_TMP_DIR="./exports"
TEMP_UPLOAD_DIR="./tmp-uploads"
EXPORT_TOKEN_TTL_MINUTES=30
WORKER_RPC_TIMEOUT_MS=30000

# 生产 MySQL 示例：
# DATABASE_URL="mysql://user:pass@127.0.0.1:3306/jade_accounting"
# 生产 PostgreSQL 示例：
# DATABASE_URL="postgresql://user:pass@127.0.0.1:5432/jade_accounting"
