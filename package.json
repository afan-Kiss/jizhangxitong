{
  "name": "jade-accounting-system",
  "version": "1.0.0",
  "private": true,
  "description": "和田玉镯子记账系统",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm run dev -w @jade-account/server\" \"npm run dev -w @jade-account/web\"",
    "dev:server": "npm run dev -w @jade-account/server",
    "dev:web": "npm run dev -w @jade-account/web",
    "dev:worker": "npm run dev -w @jade-account/worker",
    "build": "npm run build -w @jade-account/shared && npm run build -w @jade-account/server && npm run build -w @jade-account/web && npm run build -w @jade-account/worker",
    "start:prod": "npm run start -w @jade-account/server",
    "db:generate": "npm run db:generate -w @jade-account/server",
    "db:push": "npm run db:push -w @jade-account/server",
    "db:seed": "npm run db:seed -w @jade-account/server",
    "acceptance": "node scripts/auto-acceptance.mjs",
    "acceptance:full": "node scripts/auto-acceptance.mjs full",
    "acceptance:cleanup": "node scripts/acceptance-cleanup.mjs",
    "worker:status": "npm run status -w @jade-account/worker",
    "setup:secrets": "node scripts/setup-secrets.mjs",
    "setup:admin": "node scripts/setup-admin.mjs",
    "set:admin-password": "node scripts/set-admin-password.mjs",
    "db:prepare-prod": "node scripts/db-prepare-prod.mjs",
    "health-check": "node scripts/system-health-check.mjs",
    "check:autostart": "node scripts/check-autostart.mjs",
    "check:backup": "node scripts/check-backup-status.mjs",
    "deploy:aliyun": "node scripts/deploy-aliyun.mjs",
    "rotate:worker-token": "node scripts/rotate-worker-token.mjs",
    "rotate:admin-password": "node scripts/rotate-admin-password.mjs",
    "acceptance:remote": "node scripts/remote-acceptance.mjs",
    "test:subpath": "node scripts/test-subpath-refresh.mjs",
    "test:login": "node scripts/test-login.mjs",
    "test:white-screen": "node scripts/test-white-screen.mjs",
    "test:responsive": "node scripts/test-responsive.mjs",
    "test:worker-online": "node scripts/test-worker-online.mjs",
    "test:assets": "node scripts/check-assets-remote.mjs",
    "cleanup:stuck-tests": "node scripts/cleanup-stuck-tests.mjs",
    "guard:no-networkidle": "node scripts/guard-no-networkidle.mjs",
    "test:scan-binding": "node scripts/test-scan-binding.mjs",
    "verify:deploy-version": "node scripts/verify-deploy-version.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "exceljs": "^4.4.0",
    "playwright": "^1.61.1"
  }
}
